{
  "name": "makers_QA_prueba",
  "version": "1.0.0",
  "descripcion": "challenge makers prueba",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "test:ui": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    "test:api": "cypress run --spec 'api/automated-tests/**/*.cy.js'",
    "test:open": "cypress open",
    "test:headed": "cypress run --headed --browser chrome",
    "test:ui:headed": "cypress run --headed --browser chrome --spec 'cypress/e2e/**/*.cy.js'",
    "test:api:headed": "cypress run --headed --browser chrome --spec 'api/automated-tests/**/*.cy.js'",
    "report:merge": "mochawesome-merge > cypress/reports/output.json",
    "report:generate": "marge cypress/reports/output.json --reportDir cypress/reports/html --inline",
    "report": "npm run report:merge && npm run report:generate",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "rimraf allure-results allure-report"
  },
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.40.2",
    "allure-commandline": "^2.27.0",
    "cy-spok": "^1.7.0",
    "cypress": "^15.17.0",
    "cypress-iframe": "^1.0.1",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.9.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^3.8.4",
    "rimraf": "^5.0.0"
  },
  "dependencies": {
    "cypress-plugin-api": "^2.11.2",
    "dotenv": "^16.4.7"
  }
}
